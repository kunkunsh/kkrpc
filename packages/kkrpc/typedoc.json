{
	"$schema": "https://typedoc.org/schema.json",
	"entryPoints": [
		"src/entries/mod.ts",
		"src/entries/browser-mod.ts",
		"src/entries/http.ts",
		"src/entries/chrome-extension.ts",
		"src/entries/deno-mod.ts",
		"src/entries/socketio.ts",
		"src/entries/rabbitmq.ts",
		"src/entries/kafka.ts",
		"src/entries/redis-streams.ts",
		"src/entries/nats.ts",
		"src/entries/electron.ts",
		"src/entries/tauri.ts",
		"src/entries/inspector.ts"
	],
	"visibilityFilters": {
		"protected": false,
		"private": false,
		"inherited": true,
		"external": true
	},
	"out": "docs",
	"exclude": ["__deno_tests__/**/*"],
	"skipErrorChecking": true
}
