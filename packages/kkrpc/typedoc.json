{
	"$schema": "https://typedoc.org/schema.json",
	"entryPoints": [
		"mod.ts",
		"browser-mod.ts",
		"http.ts",
		"chrome-extension.ts",
		"deno-mod.ts",
		"socketio.ts",
		"rabbitmq.ts",
		"kafka.ts",
		"redis-streams.ts",
		"nats.ts",
		"electron.ts",
		"electron-ipc.ts",
		"inspector.ts"
	],
	"visibilityFilters": {
		"protected": false,
		"private": false,
		"inherited": true,
		"external": true
	},
	"out": "docs",
	"exclude": ["__deno_tests__/**/*"],
	"skipErrorChecking": true
}
