{
	"name": "@kunkun/kkrpc",
	"version": "1.0.0-beta.1",
	"description": "TypeScript-first RPC library for seamless bi-directional communication between processes, workers, and contexts. Cross-runtime compatible with Node.js, Deno, Bun, and browsers.",
	"keywords": [
		"rpc",
		"typescript",
		"remote-procedure-call",
		"type-safe",
		"bidirectional",
		"cross-runtime",
		"nodejs",
		"deno",
		"bun",
		"browser",
		"web-worker",
		"chrome-extension",
		"tauri",
		"ipc",
		"inter-process-communication",
		"extension-system",
		"plugin-architecture",
		"microservices",
		"worker-communication",
		"cross-context",
		"stdio",
		"http",
		"websocket",
		"postmessage"
	],
	"tasks": {
		"dev": "deno run --watch main.ts"
	},
	"exports": {
		".": "./src/entries/mod.ts",
		"./browser": "./src/entries/browser-mod.ts",
		"./deno": "./src/entries/deno-mod.ts",
		"./transport": "./src/entries/transport.ts",
		"./codecs": "./src/entries/codecs.ts",
		"./plugins": "./src/entries/plugins.ts",
		"./validation": "./src/entries/validation.ts",
		"./middleware": "./src/entries/middleware.ts",
		"./superjson": "./src/entries/superjson.ts",
		"./worker": "./src/entries/worker.ts",
		"./stdio": "./src/entries/stdio.ts",
		"./http": "./src/entries/http.ts",
		"./ws": "./src/entries/ws.ts",
		"./ws/hono": "./src/entries/ws-hono.ts",
		"./ws/elysia": "./src/entries/ws-elysia.ts",
		"./iframe": "./src/entries/iframe.ts",
		"./chrome-extension": "./src/entries/chrome-extension.ts",
		"./electron": "./src/entries/electron.ts",
		"./tauri": "./src/entries/tauri.ts",
		"./socketio": "./src/entries/socketio.ts",
		"./rabbitmq": "./src/entries/rabbitmq.ts",
		"./kafka": "./src/entries/kafka.ts",
		"./redis-streams": "./src/entries/redis-streams.ts",
		"./nats": "./src/entries/nats.ts",
		"./relay": "./src/entries/relay.ts",
		"./inspector": "./src/entries/inspector.ts"
	},
	"imports": {
		"@std/assert": "jsr:@std/assert@1",
		"@tauri-apps/plugin-shell": "npm:@tauri-apps/plugin-shell@^2",
		"amqplib": "npm:amqplib@^0.10",
		"superjson": "npm:superjson@^2",
		"kafkajs": "npm:kafkajs@^2",
		"ioredis": "npm:ioredis@^5",
		"socket.io-client": "npm:socket.io-client@^4",
		"@nats-io/transport-node": "npm:@nats-io/transport-node@^3"
	},
	"publish": {
		"exclude": ["node_modules", "dist", "__tests__", "__deno_tests__", "scripts"]
	},
	"lint": {
		"rules": {
			"exclude": ["no-explicit-any"]
		}
	},
	"license": "MIT"
}
